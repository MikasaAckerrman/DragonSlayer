#! /usr/bin/env python
# encoding: utf-8

def options(opt):
	pass

def configure(conf):
	if not conf.path.find_dir('silk-src') or not conf.path.find_dir('silk-src/src'):
		conf.fatal('Can\'t find SILK SDK sources in 3rdparty/silk/silk-src/.')
		return

def build(bld):
	sources = bld.path.ant_glob(['silk-src/src/*.c'])

	bld.stlib(
		source = sources,
		target = 'silk',
		features = 'c',
		includes = ['silk-src/interface', 'silk-src/src'],
		export_includes = ['silk-src/interface'],
		defines = ['NO_ASM']
	)

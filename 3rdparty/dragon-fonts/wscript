#! /usr/bin/env python
# encoding: utf-8
#
# dragon-fonts wscript
# Packs gfx/fonts/<name>.ttf + LICENSE.OFL into a pk3 the engine can mount.
# Mirrors the structure of 3rdparty/extras/wscript so the install location is
# the same as extras.pk3 (the gamedir on Android, SHAREDIR/GAMEDIR elsewhere).

import os

def options(opt):
	pass

def configure(conf):
	conf.load('zip')

def build(bld):
	srcdir = bld.path

	if bld.env.DEST_OS in ['android']:
		install_path = bld.env.PREFIX
	else:
		install_path = os.path.join(bld.env.SHAREDIR, bld.env.GAMEDIR)

	# Glob TTFs and the OFL license. The pk3 must contain the LICENSE.OFL
	# alongside the font (OFL clause 2 - "must contain the above copyright
	# notice and this license"). README.md and this wscript itself are NOT
	# packaged - the pk3 ships the user-facing artefacts only.
	bld(features='zip',
		name='dragon-fonts.pk3',
		files=srcdir.ant_glob('gfx/fonts/*.ttf') + srcdir.ant_glob('LICENSE.OFL'),
		relative_to=srcdir,
		install_path=install_path)
